APP_NAME=SoundTag API
DEBUG=false
JWT_SECRET=replace-with-a-long-random-production-secret
ACCESS_TOKEN_EXPIRE_HOURS=168
DATABASE_URL=postgresql+psycopg://soundtag:soundtag@127.0.0.1:5432/soundtag
CORS_ORIGINS=["http://localhost:8081","http://localhost:19006","http://127.0.0.1:19006"]
DEBUG_EXPOSE_OTP=false

# Production should use a real SMS provider.
SMS_PROVIDER=aliyun_pnvs
SMS_CODE_EXPIRE_MINUTES=5
SMS_RESEND_COOLDOWN_SECONDS=60
SMS_SIGN_NAME=
SMS_TEMPLATE_CODE=
SMS_TEMPLATE_CODE_KEY=code
ALIYUN_SMS_ENDPOINT=dypnsapi.aliyuncs.com
ALIYUN_PNVS_ENDPOINT=dypnsapi.aliyuncs.com
ALIYUN_VERIFY_SCHEME_NAME=
ALIYUN_VERIFY_CODE_LENGTH=6
ALIYUN_VERIFY_CODE_TYPE=1
ALIYUN_VERIFY_VALID_TIME_SECONDS=300
ALIYUN_VERIFY_DUPLICATE_POLICY=1
ALIYUN_VERIFY_INTERVAL_SECONDS=60
ALIYUN_VERIFY_RETURN_CODE=false
ALIYUN_VERIFY_AUTO_RETRY=1

ALIYUN_ACCESS_KEY_ID=
ALIYUN_ACCESS_KEY_SECRET=
ALIYUN_STS_ENDPOINT=sts.cn-shanghai.aliyuncs.com
OSS_ENDPOINT=oss-cn-shanghai.aliyuncs.com
OSS_BUCKET=
OSS_ROLE_ARN=
OSS_CDN_BASE_URL=
OSS_STS_DURATION_SECONDS=1800
OSS_OBJECT_PREFIX=audio
